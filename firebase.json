{
  "firestore": {
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "functions": [
    {
      "source": "firebase/functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "predeploy": [
        "pnpm --filter firebase-functions-scr-mesh build"
      ]
    }
  ],
  "hosting": [
    {
      "target": "admin",
      "public": "apps/web-admin/public",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "web-admin",
            "region": "us-central1"
          }
        }
      ]
    },
    {
      "target": "public",
      "public": "apps/web-public/public",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "web-public",
            "region": "us-central1"
          }
        }
      ]
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "ui": { "enabled": true },
    "singleProjectMode": false
  }
}
