{
  "name": "mesh-coordinator",
  "version": "0.0.1",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./coordinate": {
      "types": "./src/coordinate.ts",
      "default": "./src/coordinate.ts"
    },
    "./firestore": {
      "types": "./src/firestore.ts",
      "default": "./src/firestore.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@scr-mesh/types": "workspace:*",
    "@scr-mesh/constants": "workspace:*",
    "@scr-mesh/playbooks": "workspace:*",
    "@google/generative-ai": "^0.14.0",
    "@google-cloud/pubsub": "^4.4.0",
    "firebase-admin": "^12.1.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.10.0",
    "@types/node": "^20.12.0",
    "@types/express": "^4.17.21",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.12"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["<rootDir>/src/**/*.test.ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
