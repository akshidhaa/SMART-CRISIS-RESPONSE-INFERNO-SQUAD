# ─────────────────────────────────────────────────────────────────────────────
# deploy/.env.example
# Copy this to .env.deploy (gitignored), fill in real values,
# then source it before running deploy commands:
#   source .env.deploy
# ─────────────────────────────────────────────────────────────────────────────

# ── GCP / Firebase project ───────────────────────────────────────────────────
PROJECT_ID=scr-mesh-prod           # your GCP project ID
REGION=us-central1                 # Cloud Run region
FIREBASE_PROJECT_ID=scr-mesh-prod  # same as PROJECT_ID (Firebase uses GCP project)

# ── Firebase web config (from Firebase Console → Project Settings → Your apps)
# These are baked into the Next.js bundle at docker build time
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=scr-mesh-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=scr-mesh-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=scr-mesh-prod.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Gemini API ────────────────────────────────────────────────────────────────
# Store in GCP Secret Manager, not here. This is just for reference.
# Command: gcloud secrets create gemini-api-key --data-file=- <<< "YOUR_KEY"
GEMINI_API_KEY=AIza...

# ── Twilio (used by Firebase Functions for SMS notifications) ─────────────────
# Set via: firebase functions:secrets:set TWILIO_ACCOUNT_SID
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Container registry ────────────────────────────────────────────────────────
# Image names produced by the build script
REGISTRY=gcr.io/${PROJECT_ID}
IMAGE_WEB_ADMIN=${REGISTRY}/web-admin
IMAGE_WEB_PUBLIC=${REGISTRY}/web-public
IMAGE_GEMINI=${REGISTRY}/gemini-orchestrator
IMAGE_AI_DETECTION=${REGISTRY}/ai-detection
IMAGE_MESH_COORDINATOR=${REGISTRY}/mesh-coordinator
