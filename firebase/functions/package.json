{
  "name": "firebase-functions-scr-mesh",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch --project tsconfig.json",
    "lint": "tsc --noEmit",
    "serve": "firebase emulators:start --only functions"
  },
  "dependencies": {
    "firebase-functions": "^5.0.0",
    "firebase-admin": "^12.1.0",
    "@google-cloud/pubsub": "^4.4.0",
    "twilio": "^5.0.0",
    "@scr-mesh/types": "workspace:*",
    "@scr-mesh/constants": "workspace:*",
    "@scr-mesh/playbooks": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.12",
    "firebase-functions-test": "^3.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["<rootDir>/src/**/*.test.ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
